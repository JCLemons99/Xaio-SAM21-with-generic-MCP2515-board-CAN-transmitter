#include <mcp_can.h>
#include <SPI.h>

/* 
 * XIAO ESP32S3 + XIAO CAN Expansion Board Configuration
 * CS Pin: D1 (GPIO 2)
 * Crystal: 8MHz
 */
const int SPI_CS_PIN = D1; 
MCP_CAN CAN(SPI_CS_PIN);

void setup() {
    Serial.begin(115200);
    while (!Serial); // Wait for Serial Monitor to open

    /* 
     * FIX: begin() requires 3 arguments:
     * 1. ID Mode: MCP_ANY (receives all messages)
     * 2. Baud Rate: CAN_500KBPS (Standard for most OBD2)
     * 3. Crystal: MCP_8MHZ (Standard for XIAO CAN Board)
     */
    Serial.println("Initializing CAN...");
    while (CAN_OK != CAN.begin(MCP_ANY, CAN_500KBPS, MCP_8MHZ)) {
        Serial.println("CAN BUS Shield init fail. Retrying...");
        delay(500);
    }
    
    // Set mode to NORMAL so the chip can transmit and acknowledge
    CAN.setMode(MCP_NORMAL); 
    Serial.println("CAN BUS Shield init ok!");
}

void loop() {
    /* 
     * OBD2 Request for Engine RPM (PID 0x0C)
     * Standard Request ID: 0x7DF
     * Data: [Len=2, Mode=01, PID=0x0C, 0, 0, 0, 0, 0]
     */
    unsigned char requestData[8] = {0x02, 0x01, 0x0C, 0x00, 0x00, 0x00, 0x00, 0x00};
    
    if (CAN.sendMsgBuf(0x7DF, 0, 8, requestData) == CAN_OK) {
        // Delay to allow ECU to respond
        delay(100); 

        unsigned long rxId;
        unsigned char len = 0;
        unsigned char rxBuf[8];

        // Check for incoming messages
        if (CAN_MSGAVAIL == CAN.checkReceive()) {
            CAN.readMsgBuf(&rxId, &len, rxBuf);

            /* 
             * OBD2 Response Check:
             * Byte 1: Mode + 0x40 (0x41)
             * Byte 2: PID (0x0C)
             * Byte 3: RPM High Byte (A)
             * Byte 4: RPM Low Byte (B)
             */
            if (rxBuf[1] == 0x41 && rxBuf[2] == 0x0C) {
                // RPM Formula: ((A*256)+B)/4
                unsigned int rpm = ((unsigned int)rxBuf[3] * 256 + rxBuf[4]) / 4;
                Serial.print("Engine RPM: ");
                Serial.println(rpm);
            }
        }
    } else {
        Serial.println("Error sending RPM request.");
    }

    delay(200); // Poll RPM 5 times per second
}
